---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '커밋 기록에서 자동 생성된 개발 블로그' } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header>
      <nav class="max-w-2xl mx-auto px-6 py-6 flex items-center justify-between">
        <a href={base} class="text-base font-semibold tracking-tight hover:opacity-70 transition-opacity">
          Commit Blog
        </a>
        <div class="flex gap-6 text-sm text-muted dark:text-muted-dark">
          <a href={base} class="hover:text-text dark:hover:text-text-dark transition-colors">홈</a>
          <a href={`${base}blog`} class="hover:text-text dark:hover:text-text-dark transition-colors">글 목록</a>
          <a href={`${base}about`} class="hover:text-text dark:hover:text-text-dark transition-colors">소개</a>
          <a href="https://windowispark.github.io/" target="_blank" rel="noopener noreferrer"
             class="hover:text-text dark:hover:text-text-dark transition-colors">
            포트폴리오 <span class="inline-block text-[10px] opacity-50">↗</span>
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1 mx-auto px-6 py-16 w-full max-w-2xl">
      <slot />
    </main>

    <footer>
      <div class="max-w-2xl mx-auto px-6 py-8 text-xs text-muted dark:text-muted-dark text-center tracking-wide">
        Powered by Astro & Claude
      </div>
    </footer>
  </body>
</html>
