---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '커밋 기록에서 자동 생성된 개발 블로그' } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-border dark:border-border-dark">
      <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="text-lg font-bold">Commit Blog</a>
        <div class="flex gap-4 text-sm text-muted">
          <a href="/" class="hover:text-text dark:hover:text-text-dark">홈</a>
          <a href="/blog" class="hover:text-text dark:hover:text-text-dark">글 목록</a>
          <a href="/about" class="hover:text-text dark:hover:text-text-dark">소개</a>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-3xl mx-auto px-4 py-8 w-full">
      <slot />
    </main>

    <footer class="border-t border-border dark:border-border-dark">
      <div class="max-w-3xl mx-auto px-4 py-6 text-sm text-muted text-center">
        커밋 기록에서 자동 생성된 블로그 &middot; Powered by Astro & Claude
      </div>
    </footer>
  </body>
</html>
