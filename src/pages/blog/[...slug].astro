---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RepoTag from '../../components/RepoTag.astro';
import PostNav from '../../components/PostNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allSorted = posts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  return posts.map((post) => {
    const sameRepoPosts = allSorted.filter(p => p.data.repo === post.data.repo);
    const idx = sameRepoPosts.findIndex(p => p.id === post.id);
    const prevPost = sameRepoPosts[idx + 1] ?? null;
    const nextPost = sameRepoPosts[idx - 1] ?? null;

    return {
      params: { slug: post.id },
      props: {
        post,
        prevPost: prevPost ? { slug: prevPost.id, title: prevPost.data.title } : null,
        nextPost: nextPost ? { slug: nextPost.id, title: nextPost.data.title } : null,
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
// 한글+mono 혼합 렌더를 피하기 위해 숫자 포맷 사용 (예: 2026.04.09)
const formattedDate = post.data.pubDate.toISOString().slice(0, 10).replaceAll('-', '.');
const repoName = post.data.repoDisplayName ?? post.data.repo;
const repoFilterURL = `${base}blog/?repo=${encodeURIComponent(post.data.repo)}`;
---

<BaseLayout title={`${post.data.title} | Commit Blog`} description={post.data.description}>
  <nav aria-label="브레드크럼" class="text-xs text-muted dark:text-muted-dark mb-8 flex items-center gap-1.5 font-mono">
    <a href={base} class="hover:text-text dark:hover:text-text-dark transition-colors">홈</a>
    <span class="opacity-40" aria-hidden="true">/</span>
    <a href={`${base}blog`} class="hover:text-text dark:hover:text-text-dark transition-colors">글 목록</a>
    <span class="opacity-40" aria-hidden="true">/</span>
    <a href={repoFilterURL} class="hover:text-text dark:hover:text-text-dark transition-colors">{repoName}</a>
    <span class="opacity-40" aria-hidden="true">/</span>
    <span aria-current="page" class="text-text dark:text-text-dark truncate max-w-[40vw] sm:max-w-xs">{post.data.title}</span>
  </nav>

  <article>
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <a href={repoFilterURL} class="hover:opacity-70 transition-opacity" aria-label={`${repoName} 글 목록 보기`}>
          <RepoTag repo={post.data.repo} displayName={post.data.repoDisplayName} />
        </a>
        <time class="text-xs text-muted dark:text-muted-dark font-mono">{formattedDate}</time>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-3">{post.data.title}</h1>
      <p class="text-muted dark:text-muted-dark text-lg leading-relaxed">{post.data.description}</p>
      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag: string) => (
            <a
              href={`${base}tags/${tag}`}
              class="text-xs text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <Content />
    </div>

    {post.data.commits.length > 0 && (
      <footer class="mt-16 pt-8 border-t border-border dark:border-border-dark">
        <details class="text-sm">
          <summary class="cursor-pointer text-xs text-muted dark:text-muted-dark
                          hover:text-text dark:hover:text-text-dark
                          transition-colors font-medium uppercase tracking-widest">
            관련 커밋 ({post.data.commits.length})
          </summary>
          <ul class="mt-3 space-y-1.5 font-mono text-xs text-muted dark:text-muted-dark">
            {post.data.commits.map((sha: string) => (
              <li>
                <a
                  href={`https://github.com/WindowisPark/${post.data.repo}/commit/${sha}`}
                  class="hover:text-accent dark:hover:text-accent-dark transition-colors"
                  target="_blank"
                  rel="noopener"
                >
                  {sha.slice(0, 7)}
                </a>
              </li>
            ))}
          </ul>
        </details>
      </footer>
    )}
  </article>

  <PostNav prevPost={prevPost} nextPost={nextPost} repoName={repoName} />
</BaseLayout>
