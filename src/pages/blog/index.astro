---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import RepoTag from '../../components/RepoTag.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const repoMap = new Map<string, { displayName: string; posts: typeof posts }>();
for (const post of posts) {
  const repo = post.data.repo;
  if (!repoMap.has(repo)) {
    repoMap.set(repo, { displayName: post.data.repoDisplayName ?? repo, posts: [] });
  }
  repoMap.get(repo)!.posts.push(post);
}
const repoEntries = [...repoMap.entries()];
---

<BaseLayout title="글 목록 | Commit Blog">
  <div class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight mb-2">글 목록</h1>
    <p class="text-sm text-muted dark:text-muted-dark">총 {posts.length}개의 포스트</p>
  </div>

  <nav class="flex flex-wrap gap-2 mb-12">
    <button
      class="tab-filter text-sm px-3 py-1.5 rounded-md transition-colors font-medium
             bg-text text-bg dark:bg-text-dark dark:text-bg-dark"
      data-repo="all"
    >
      전체 <span class="opacity-50 text-xs ml-0.5">{posts.length}</span>
    </button>
    {repoEntries.map(([repo, { displayName, posts: repoPosts }]) => (
      <button
        class="tab-filter text-sm px-3 py-1.5 rounded-md transition-colors
               text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark
               hover:bg-bg-subtle dark:hover:bg-bg-dark-subtle"
        data-repo={repo}
      >
        {displayName} <span class="opacity-50 text-xs ml-0.5">{repoPosts.length}</span>
      </button>
    ))}
  </nav>

  {repoEntries.map(([repo, { displayName, posts: repoPosts }]) => (
    <section id={repo} class="repo-section mb-12" data-repo={repo}>
      <div class="flex items-center gap-3 mb-6">
        <RepoTag repo={repo} displayName={displayName} />
        <span class="text-xs text-muted dark:text-muted-dark">{repoPosts.length}개의 포스트</span>
      </div>
      {repoPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          repo={post.data.repo}
          repoDisplayName={post.data.repoDisplayName}
          tags={post.data.tags}
          slug={post.id}
        />
      ))}
    </section>
  ))}
</BaseLayout>

<script>
  function initTabFilter() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.tab-filter');
    const sections = document.querySelectorAll<HTMLElement>('.repo-section');

    const activeClasses = ['bg-text', 'text-bg', 'dark:bg-text-dark', 'dark:text-bg-dark', 'font-medium'];
    const inactiveClasses = ['text-muted', 'dark:text-muted-dark'];

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const repo = tab.dataset.repo;

        tabs.forEach((t) => {
          t.classList.remove(...activeClasses);
          t.classList.add(...inactiveClasses);
        });
        tab.classList.remove(...inactiveClasses);
        tab.classList.add(...activeClasses);

        if (repo === 'all') {
          sections.forEach((s) => s.style.display = '');
        } else {
          sections.forEach((s) => {
            s.style.display = s.dataset.repo === repo ? '' : 'none';
          });
        }
      });
    });
  }
  initTabFilter();
  document.addEventListener('astro:after-swap', initTabFilter);
</script>
