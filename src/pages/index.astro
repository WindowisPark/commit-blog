---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const recentPosts = posts.slice(0, 10);
---

<BaseLayout title="Commit Blog">
  <section class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Commit Blog</h1>
    <p class="text-muted">커밋 기록에서 자동 생성된 개발 블로그입니다.</p>
  </section>

  <section>
    {recentPosts.length === 0 ? (
      <p class="text-muted py-8">아직 포스트가 없습니다. 파이프라인을 실행해 보세요.</p>
    ) : (
      recentPosts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          repo={post.data.repo}
          repoDisplayName={post.data.repoDisplayName}
          tags={post.data.tags}
          slug={post.id}
        />
      ))
    )}
  </section>

  {posts.length > 10 && (
    <div class="mt-8 text-center">
      <a href="/blog" class="text-primary hover:underline">모든 글 보기 →</a>
    </div>
  )}
</BaseLayout>
