---
interface NavPost {
  slug: string;
  title: string;
}

interface Props {
  prevPost?: NavPost | null;
  nextPost?: NavPost | null;
}

const { prevPost, nextPost } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

{(prevPost || nextPost) && (
  <nav class="flex justify-between gap-4 mt-8 pt-6 border-t border-border dark:border-border-dark text-sm">
    <div class="flex-1 min-w-0">
      {prevPost && (
        <a href={`${base}blog/${prevPost.slug}`} class="group block">
          <span class="text-muted text-xs">← 이전 글</span>
          <p class="truncate text-text dark:text-text-dark group-hover:text-primary transition-colors">
            {prevPost.title}
          </p>
        </a>
      )}
    </div>
    <div class="flex-1 min-w-0 text-right">
      {nextPost && (
        <a href={`${base}blog/${nextPost.slug}`} class="group block">
          <span class="text-muted text-xs">다음 글 →</span>
          <p class="truncate text-text dark:text-text-dark group-hover:text-primary transition-colors">
            {nextPost.title}
          </p>
        </a>
      )}
    </div>
  </nav>
)}
