---
interface NavPost {
  slug: string;
  title: string;
}

interface Props {
  prevPost?: NavPost | null;
  nextPost?: NavPost | null;
}

const { prevPost, nextPost } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

{(prevPost || nextPost) && (
  <nav class="flex justify-between gap-8 mt-16 pt-8 border-t border-border dark:border-border-dark">
    <div class="flex-1 min-w-0">
      {prevPost && (
        <a href={`${base}blog/${prevPost.slug}`} class="group block">
          <span class="text-xs text-muted dark:text-muted-dark uppercase tracking-widest">이전</span>
          <p class="mt-1 text-sm truncate text-text dark:text-text-dark
                     group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
            <span class="inline-block transition-transform group-hover:-translate-x-1">←</span>
            {prevPost.title}
          </p>
        </a>
      )}
    </div>
    <div class="flex-1 min-w-0 text-right">
      {nextPost && (
        <a href={`${base}blog/${nextPost.slug}`} class="group block">
          <span class="text-xs text-muted dark:text-muted-dark uppercase tracking-widest">다음</span>
          <p class="mt-1 text-sm truncate text-text dark:text-text-dark
                     group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
            {nextPost.title}
            <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
          </p>
        </a>
      )}
    </div>
  </nav>
)}
