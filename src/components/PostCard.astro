---
import RepoTag from './RepoTag.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  repo: string;
  repoDisplayName?: string;
  tags: string[];
  slug: string;
}

const { title, description, pubDate, repo, repoDisplayName, tags, slug } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
const formattedDate = pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group py-6">
  <a href={`${base}blog/${slug}`}
     class="block -mx-4 px-4 py-4 rounded-lg hover:bg-bg-subtle dark:hover:bg-bg-dark-subtle transition-colors duration-200">
    <div class="flex items-center gap-3 mb-3">
      <RepoTag repo={repo} displayName={repoDisplayName} />
      <time class="text-xs text-muted dark:text-muted-dark font-mono">{formattedDate}</time>
    </div>
    <h2 class="text-lg font-semibold tracking-tight mb-1.5
               group-hover:text-accent dark:group-hover:text-accent-dark transition-colors duration-200">
      {title}
    </h2>
    <p class="text-sm text-muted dark:text-muted-dark leading-relaxed line-clamp-2">{description}</p>
  </a>
  {tags.length > 0 && (
    <div class="flex gap-2 mt-2">
      {tags.map((tag) => (
        <a
          href={`${base}tags/${tag}`}
          class="text-xs text-muted dark:text-muted-dark hover:text-text dark:hover:text-text-dark transition-colors"
        >
          #{tag}
        </a>
      ))}
    </div>
  )}
</article>
