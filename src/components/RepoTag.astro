---
interface Props {
  repo: string;
  displayName?: string;
}

const { repo, displayName } = Astro.props;

const dotColors: Record<string, string> = {
  'Dividend1s': 'bg-blue-500',
  'fitin': 'bg-emerald-500',
  'SpotPrice': 'bg-amber-500',
  'lock-bench': 'bg-violet-500',
  'jobmate': 'bg-rose-500',
  'kbo-prediction': 'bg-cyan-500',
};

const dotColor = dotColors[repo] ?? 'bg-gray-400';
---

<span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md text-xs font-medium
             bg-bg-subtle text-muted dark:bg-bg-dark-subtle dark:text-muted-dark
             border border-border dark:border-border-dark">
  <span class={`w-1.5 h-1.5 rounded-full ${dotColor}`}></span>
  {displayName ?? repo}
</span>
