---
interface Props {
  repo: string;
  displayName?: string;
}

const { repo, displayName } = Astro.props;

const colors: Record<string, string> = {
  'Dividend1s': 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200',
  'fitin': 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200',
};

const colorClass = colors[repo] ?? 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-200';
---

<span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${colorClass}`}>
  {displayName ?? repo}
</span>
